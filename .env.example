# ── Sanity (CMS) ─────────────────────────────────────────────
# La maqueta FUNCIONA SIN ESTO: si no defines estas variables,
# el sitio usa datos semilla locales (lib/seed-data.ts).
# Para conectar el CMS real:
#   1) npx sanity@latest login
#   2) npx sanity@latest init  (crea el proyecto y te da el Project ID)
#   3) copia los valores aqui en un archivo .env.local
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ── Lectura del CMS (catálogo en vivo) ───────────────────────
# Token de SOLO LECTURA (rol "Viewer") de Sanity. NECESARIO para que la tienda
# muestre los productos del CMS (este dataset requiere token para leer documentos).
# Sin él, el sitio usa el catálogo semilla. Créalo en:
#   https://www.sanity.io/manage -> proyecto BigBiker -> API -> Tokens (Viewer)
# Debe quedar SOLO en el servidor (sin prefijo NEXT_PUBLIC).
SANITY_API_READ_TOKEN=

# ── Analítica real (escritura) ───────────────────────────────
# Token de Sanity con permiso de ESCRITURA (rol "Editor").
# Necesario SOLO para registrar tráfico/ventas reales (/api/track).
# Sin él, el dashboard funciona pero muestra 0 hasta que se configure.
# Créalo en https://www.sanity.io/manage -> proyecto -> API -> Tokens
# y ponlo aquí (NUNCA con prefijo NEXT_PUBLIC: debe quedar solo en el servidor).
SANITY_API_WRITE_TOKEN=

# ── SEO ──────────────────────────────────────────────────────
# Dominio canónico de producción (sin barra final). Define metadataBase,
# sitemap, robots y las URLs absolutas de los datos estructurados.
NEXT_PUBLIC_SITE_URL=https://www.bigbiker.com.co
# Token de verificación de Google Search Console (opcional).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Contacto / WhatsApp (UI) ─────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=573006098946
NEXT_PUBLIC_CONTACT_EMAIL=info@bigbiker.com.co
NEXT_PUBLIC_CONTACT_ADDRESS=Calle 7 #83A-24 Interior 143, Medellin
